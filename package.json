{
  "name": "@blakfy/accessibility-widget-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Monorepo for @blakfy/accessibility-widget v2 — CDN-distributed accessibility preferences widget for Next.js + vanilla sites",
  "license": "MIT",
  "author": "Tarık Tunç (Blakfy Studio)",
  "homepage": "https://github.com/tariktunc/accessibility-widget",
  "repository": {
    "type": "git",
    "url": "https://github.com/tariktunc/accessibility-widget.git"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm -r --parallel --filter './packages/*' dev",
    "test": "pnpm -r --filter './packages/*' test",
    "test:contract": "pnpm -r --filter './packages/*' test:contract",
    "test:e2e": "pnpm -r --filter './packages/*' test:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:manual": "node scripts/publish-manual.mjs",
    "api:check": "pnpm -r --filter \"@blakfy/a11y-core\" --filter \"@blakfy/accessibility-widget\" --filter \"@blakfy/accessibility-widget-next\" --workspace-concurrency=1 api:check",
    "api:update": "pnpm -r --filter \"@blakfy/a11y-core\" --filter \"@blakfy/accessibility-widget\" --filter \"@blakfy/accessibility-widget-next\" --workspace-concurrency=1 api:update",
    "docs:reference": "typedoc",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.vite",
    "clean:all": "pnpm clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^22.19.17",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "size-limit": "^12.1.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
