{
  "name": "@blakfy/a11y-core",
  "version": "2.0.0-alpha.1",
  "description": "Framework-agnostic core for @blakfy/accessibility-widget — preferences, i18n, schema, events",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.4",
    "jsdom": "^25.0.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
